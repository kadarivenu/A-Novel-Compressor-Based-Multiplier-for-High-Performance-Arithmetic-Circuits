module wallace_8x8(
    input [7:0] A,
    input [7:0] B,
    output [15:0] P
);
    // Partial Products
    wire pp[7:0][7:0];
    genvar i,j;
    generate
        for(i=0;i<8;i=i+1) begin
            for(j=0;j<8;j=j+1) begin
                assign pp[i][j] = A[j] & B[i]; 
            end
        end
    endgenerate
    // COLUMN 0
    assign P[0] = pp[0][0];
    // COLUMN 1
    wire c1;
    half_adder ha1(pp[0][1], pp[1][0], P[1], c1);
    // COLUMN 2
    wire s2, c2, c3;
    full_adder fa2(pp[0][2], pp[1][1], pp[2][0], s2, c2);
    half_adder ha2(s2, c1, P[2], c3);
    // COLUMN 3
    wire s4, c4, cout1, c5;
    compressor_4_2 comp3(pp[0][3], pp[1][2], pp[2][1], pp[3][0], c2, s4, c4, cout1);
    half_adder ha3(s4, c3, P[3], c5);
    // COLUMN 4
    wire s6, c6, cout2, s7, c7, c8;
    compressor_4_2 comp4(pp[0][4], pp[1][3], pp[2][2], pp[3][1], c4, s6, c6, cout2);
    full_adder fa4(c5, pp[4][0], cout1, s7, c7);
    half_adder ha4(s6, s7, P[4], c8);
    // COLUMN 5
    wire s9,c9,cout3,s10,c10,cout4,c11;
    compressor_4_2 comp5(pp[0][5], pp[1][4], pp[2][3], pp[3][2], c6, s9, c9, cout3);
    compressor_4_2 comp5b(pp[4][1], pp[5][0], c7, c8, cout2, s10, c10, cout4);
    half_adder ha5(s9, s10, P[5], c11);
    // COLUMN 6
    wire s12,c12,cout5,s13,c13,cout6,s14,c14,c15;
    compressor_4_2 comp6(pp[0][6], pp[1][5], pp[2][4], pp[3][3], c9, s12, c12, cout5);
    compressor_4_2 comp6b(pp[4][2], pp[5][1], pp[6][0], cout3, c10, s13, c13, cout6);
    full_adder k(s12, s13, cout4, s14, c14);
    half_adder ha6(s14, c11, P[6], c15);
    // COLUMN 7
    wire s16,c16,cout7,s17,c17,cout8,s18,c18,cout9,c19;
    compressor_4_2 comp7(pp[0][7], pp[1][6], pp[2][5], pp[3][4], c12, s16, c16, cout7);
    compressor_4_2 comp7b(pp[4][3], pp[5][2], pp[6][1], pp[7][0], cout5, s17, c17, cout8);
    compressor_4_2 k1(s16, s17, c13, cout6, c14, s18, c18, cout9);
    half_adder ha7(s18, c15, P[7], c19);
    // COLUMN 8
    wire s20,c20,cout10,s21,c21,cout11,s22,c22,cout12,c23;
    compressor_4_2 comp8(pp[1][7], pp[2][6], pp[3][5], pp[4][4], c16, s20, c20, cout10);
    compressor_4_2 comp8b(pp[5][3], pp[6][2], pp[7][1], cout7, c17, s21, c21, cout11);
    compressor_4_2 k2(s20, s21, cout8, cout9, c18, s22, c22, cout12);
    half_adder ha8(s22, c19, P[8], c23);
    // COLUMN 9
    wire s24,c24,cout13,s25,c25,cout14,c26,cout15;
    compressor_4_2 k3(pp[2][7], pp[3][6], pp[4][5], pp[5][4], c20, s24, c24, cout13);
    compressor_4_2 k4(pp[6][3], pp[7][2], cout10, c21, cout11, s25, c25, cout14);
    compressor_4_2 k5(s24, s25, c22, cout12, c23, P[9], c26, cout15);
    // COLUMN 10
    wire s27,c27,cout16,s28,c28,cout17,c29;
    compressor_4_2 k6(pp[3][7], pp[4][6], pp[5][5], pp[6][4], c24, s27, c27, cout16);
    compressor_4_2 k7(pp[7][3], cout13, c25, cout14, c26, s28, c28, cout17);
    full_adder fa10b(s27, s28, cout15, P[10], c29);
    // COLUMN 11
    wire s30,c30,cout18,c31,cout19;
    compressor_4_2 k8(pp[4][7], pp[5][6], pp[6][5], pp[7][4], c27, s30, c30, cout18);
    compressor_4_2 k9(cout16, c28, cout17, c29, s30, P[11], c31, cout19);
    // COLUMN 12
    wire s32,c32,cout20,c33;
    compressor_4_2 k10(pp[5][7], pp[6][6], pp[7][5], c30, cout18, s32, c32, cout20);
    full_adder fa12b(c31, cout19, s32, P[12], c33);
    // COLUMN 13
    wire s34,c34,s35,c35,c36;
    full_adder fa13(pp[6][7], pp[7][6], c32, s34, c34);
    half_adder k11(s34, cout20, s35, c35);
    half_adder k12(s35, c33, P[13], c36);
    // COLUMN 14
    wire c37,cout21;
    compressor_4_2 k13(pp[7][7], c34, c35, c36, 1'b0, P[14], c37, cout21);
    // COLUMN 15
    wire c38;
    half_adder k14(c37, cout21, P[15], c38);
endmodule
