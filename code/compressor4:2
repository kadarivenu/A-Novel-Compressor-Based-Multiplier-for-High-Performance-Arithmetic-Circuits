module compressor_4_2(
    input a, b, c, d, cin,
    output sum, carry, cout);
    wire s1, c1, c2;
   assign s1 = a ^ b ^ c;
    assign c1 = (a & b) | (b & c) | (a & c);

    assign sum = s1 ^ d ^ cin;
    assign c2 = (s1 & d) | (d & cin) | (s1 & cin);

    assign carry = c2;   // next column
    assign cout  = c1;   // next stage
endmodule
